# ══════════════════════════════════════════
#        إعدادات بوت AnonXMusic
# ══════════════════════════════════════════

# ── إعدادات تيليجرام الأساسية ─────────────
# API_ID و API_HASH: احصل عليهما من https://my.telegram.org
API_ID=
API_HASH=

# توكن البوت: احصل عليه من @BotFather
BOT_TOKEN=

# معرف مجموعة/قناة لاستقبال السجلات (رقم سالب للمجموعات)
LOGGER_ID=

# رابط قاعدة بيانات MongoDB
MONGO_URL=

# معرف حساب المالك الرئيسي للبوت
OWNER_ID=

# ── جلسات اليوزربوت ───────────────────────
# جلسة اليوزربوت الأول (مطلوبة)
SESSION=
# جلسة اليوزربوت الثاني (اختيارية)
SESSION2=
# جلسة اليوزربوت الثالث (اختيارية)
SESSION3=

# ── حدود التشغيل ──────────────────────────
# الحد الأقصى لمدة المقطع الصوتي بالدقائق (افتراضي: 60)
DURATION_LIMIT=
# الحد الأقصى لعدد المقاطع في الطابور (افتراضي: 20)
QUEUE_LIMIT=
# الحد الأقصى لعدد مقاطع البلايلست (افتراضي: 20)
PLAYLIST_LIMIT=
# الحد الأقصى لمدة تحميل أغنية عبر بحث بالدقائق (افتراضي: 20)
SONG_DOWNLOAD_LIMIT=

# ── المغادرة التلقائية ────────────────────
# مغادرة البث تلقائياً عند غياب المستمعين (True/False، افتراضي: False)
AUTO_END=
# وقت الانتظار بالثواني قبل المغادرة (افتراضي: 300)
AUTO_END_DELAY=

# ── إعدادات ArtistBots API (مطلوبة) ────────
# رابط خادم التحميل الصوتي
API_URL=
# رابط خادم التحميل المرئي (عادةً نفس API_URL)
VIDEO_API_URL=
# مفاتيح API مفصولة بفاصلة — كل مفتاح = 500 طلب/يوم
# مثال: key1,key2,key3
API_KEYS=
# مفتاح واحد فقط (بديل عن API_KEYS)
API_KEY=

# ── إعدادات اختيارية ──────────────────────
# اللغة الافتراضية (ar/en/ru/tr/zh/fr/de/es/pt/ja/hi/pa/my)
LANG_CODE=ar

# ── إعدادات yt-dlp (احتياطي للتحميل) ────────
# تفعيل الاحتياطي بـ yt-dlp عند فشل ArtistBots API (True/False، افتراضي: True)
ENABLE_COOKIES_FALLBACK=True
# رابط ملف الكوكيز من pastebin أو batbin (مفصولة بفاصلة)
# مثال: https://pastebin.com/abc123,https://batbin.me/xyz456
COOKIE_URL=
