# ── Telegram API ──────────────────────────────────────────────────────────────
API_ID=
API_HASH=

BOT_TOKEN=
LOGGER_ID=

MONGO_URL=

OWNER_ID=

SESSION=

DURATION_LIMIT=
QUEUE_LIMIT=
PLAYLIST_LIMIT=
SONG_DOWNLOAD_LIMIT=    # الحد الأقصى (بالدقائق) لتحميل أغنية عبر أمر /song أو "بحث" (افتراضي: 20)

# ── Voice Chat Auto Leave ───────────────────────────────────────────────────
AUTO_END=          # Leave the VC automatically once it has no real listeners (True/False, default: False)
AUTO_END_DELAY=    # Grace period in seconds to wait with no listeners before leaving (default: 300)

# ── ArtistBots API (مطلوب) ────────────────────────────────────────────────────
# البوت يعتمد على ArtistBots فقط للتحميل من يوتيوب.
#
# API_URL       : رابط الخادم للصوت   (مثال: https://artistbots.onrender.com)
# VIDEO_API_URL : رابط الخادم للفيديو (عادةً نفس API_URL)
# API_KEYS      : مفاتيح مفصولة بفاصلة (مثال: key1,key2,key3)
#                 كل مفتاح لديه حصة 500 طلب/يوم
#                 N مفاتيح = N×500 طلب/يوم (توزيع round-robin تلقائي)
# API_KEY       : مفتاح واحد (fallback إذا كان API_KEYS فارغاً)
API_URL=
VIDEO_API_URL=
API_KEYS=
API_KEY=
